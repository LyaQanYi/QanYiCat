{
  "name": "@qanyicat/core",
  "version": "0.0.1",
  "description": "NT Kernel layer: wrapper.node loader, Session, listeners, NT API wrappers",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./dist/config/index.mjs",
      "default": "./dist/config/index.mjs"
    }
  },
  "publishConfig": {
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs"
      },
      "./config": {
        "types": "./dist/config/index.d.ts",
        "import": "./dist/config/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sinclair/typebox": "catalog:",
    "inversify": "catalog:",
    "reflect-metadata": "catalog:",
    "winston": "catalog:",
    "winston-transport": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  }
}
